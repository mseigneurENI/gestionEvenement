{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} - import utilisateurs
{% endblock %}

{% block body %}
    <div class="display-column-centered">
        <form method="post" enctype="multipart/form-data">
            <input type="file" name="csvFile" accept=".csv" required>
            <div class="container-btn">
            <button>Importer</button>
            </div>
        </form>
        <img src="{{ asset('images/astronaut-racoon.png') }}" alt="astronaut racoon">
    </div>
{% endblock %}



